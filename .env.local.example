# Cognito — copy values from Terraform outputs after `terraform apply`
# terraform output -raw user_pool_id
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX

# terraform output -raw client_id
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS region where the Cognito pool is deployed
NEXT_PUBLIC_COGNITO_REGION=ap-south-1
